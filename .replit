modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Visual Tester"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @cyphid/centaur-server-reference dev"
waitForPort = 5000

[[workflows.workflow]]
name = "backtrack"
mode = "sequential"
author = 23295030

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git reset --hard HEAD~1"

[[workflows.workflow]]
name = "Visual Tester"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @cyphid/visual-tester exec vite dev --port 5173 --host"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Scripted rebase"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-scripted-rebase.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Hard reset to origin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/hard-reset-to-origin.sh"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173
